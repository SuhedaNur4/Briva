# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Gizli anahtar — üretimde uzun ve rastgele bir değer kullanın
SECRET_KEY=briva-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=briva-jwt-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# Veritabanı
# SQLite (geliştirme)
DATABASE_URL=sqlite:///briva.db

# PostgreSQL'e geçmek için bu satırı aktifleştirin:
# DATABASE_URL=postgresql://user:password@localhost:5432/briva_db
